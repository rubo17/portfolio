---
---
<div class="items-center w-max flex typing-container">
    <strong class="font-mono mr-1.5 -mb-[-1px] text-2xl @xl:text-3xl">&lt;</strong>
    <p
        aria-label="Hi! I'm a developer"
        class="text-xl @xl:text-2xl font-mono"
    >
        <span class="typewriter"></span>
    </p>
    <strong class="font-mono ml-1.5 text-2xl @xl:text-3xl">/&gt;</strong>
</div>

<style>
    .typing-container {
        display: none;
    }

    @media (min-height: 40rem) {
        .typing-container {
            display: flex;
        }
    }

    @keyframes typing {
        /* Software Developer */
        0.0000%,
        50% {
            content: "";
        }
        1.1395%,
        48.8605% {
            content: "S";
        }
        2.2791%,
        47.7209% {
            content: "So";
        }
        3.4186%,
        46.5814% {
            content: "Sof";
        }
        4.5581%,
        45.4419% {
            content: "Soft";
        }
        5.6977%,
        44.3023% {
            content: "Softw";
        }
        6.8372%,
        43.1628% {
            content: "Softwa";
        }
        7.9767%,
        42.0233% {
            content: "Software";
        }
        9.1163%,
        40.8837% {
            content: "Software D";
        }
        10.2558%,
        39.7442% {
            content: "Software De";
        }
        11.3953%,
        38.6047% {
            content: "Software Dev";
        }
        12.5349%,
        37.4651% {
            content: "Software Deve";
        }
        13.6744%,
        36.3256% {
            content: "Software Devel";
        }
        14.8140%,
        35.1860% {
            content: "Software Develo";
        }
        15.9535%,
        34.0465% {
            content: "Software Develop";
        }
        17.0930%,
        32.9070% {
            content: "Software Develope";
        }
        18.2326%,
        31.7674% {
            content: "Software Developer";
        }

        /* Frontend Junior */
        50%,
        100% {
            content: "";
        }
        51.1395%,
        98.8605% {
            content: "F";
        }
        52.2791%,
        97.7209% {
            content: "Fr";
        }
        53.4186%,
        96.5814% {
            content: "Fro";
        }
        54.5581%,
        95.4419% {
            content: "Fron";
        }
        55.6977%,
        94.3023% {
            content: "Front";
        }
        56.8372%,
        93.1628% {
            content: "Fronte";
        }
        57.9767%,
        92.0233% {
            content: "Fronten";
        }
        59.1163%,
        90.8837% {
            content: "Frontend";
        }
        60.2558%,
        89.7442% {
            content: "Frontend J";
        }
        61.3953%,
        88.6047% {
            content: "Frontend Ju";
        }
        62.5349%,
        87.4651% {
            content: "Frontend Jun";
        }
        63.6744%,
        86.3256% {
            content: "Frontend Juni";
        }
        64.8140%,
        85.1860% {
            content: "Frontend Junio";
        }
        65.9535%,
        84.0465% {
            content: "Frontend Junior";
        }
    }

    @keyframes blink {
        0%,
        100% {
            opacity: 1;
        }
        50% {
            opacity: 0;
        }
    }

    .typewriter {
        --caret: currentcolor;
    }

    .typewriter::before {
        content: "";
        animation: typing 12s infinite;
    }

    .typewriter::after {
        content: "";
        border-right: 1px solid var(--caret);
        animation: blink 0.5s linear infinite;
    }

    .typewriter.thick::after {
        border-right: 1ch solid var(--caret);
    }

    .typewriter.nocaret::after {
        border-right: 0;
    }

    @media (prefers-reduced-motion) {
        .typewriter::after {
            animation: none;
        }

        @keyframes sequencePopup {
            0%,
            100% {
                content: "Software Developer";
            }
            50% {
                content: "Frontend Junior";
            }
        }

        .typewriter::before {
            content: "Software Developer";
            animation: sequencePopup 12s linear infinite;
        }
    }
</style>
