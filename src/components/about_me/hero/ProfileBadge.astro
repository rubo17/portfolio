---
---
<div class="flex flex-row gap-5 items-center">
    <img
        src="/careto.jpg"
        alt="Ruben Cabrerizo Espinosa"
        loading="lazy"
        decoding="async"
        class="w-24 h-24 rounded-full object-cover"
    />
    <a
        href="https://www.linkedin.com/in/ruben-cabrerizo-274a3532b/"
        target="_blank"
        role="link"
        rel="noopener noreferrer"
        aria-label="Linkedin"
        class="flex items-center transition-transform duration-300 ease-in-out h-max"
    >
        <div class="flex items-center">
            <span class="relative inline-flex overflow-hidden rounded-full p-[1.5px]">
                <span
                    class="absolute inset-[-1000%] animate-[spin_2s_linear_infinite] bg-[conic-gradient(from_90deg_at_50%_50%,theme(colors.accent)_0%,theme(colors.accent)_50%,theme(colors.surface)_100%)]"
                ></span>
                <div
                    class="inline-flex items-center justify-center w-full px-3 py-1 text-sm text-accent bg-surface rounded-full cursor-pointer backdrop-blur-3xl whitespace-nowrap border border-accent/30 shadow-md"
                >
                    <span class="text-primaryText tracking-wide text-sm xl:text-base"
                        >Disponible para trabajar</span
                    >
                </div>
            </span>
        </div>
    </a>
</div>

<style>
    a[aria-label="Linkedin"]:hover {
        transform: scale(1.03);
    }

    a[aria-label="Linkedin"] {
        transition: transform 0.2s ease-in-out;
    }
</style>
