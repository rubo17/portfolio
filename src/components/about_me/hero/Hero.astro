---
import SocialNetworks from '@components/SocialNetworks.astro';
import ProfileBadge from './ProfileBadge.astro';
import TypewriterText from './TypewriterText.astro';
import HeroActions from './HeroActions.astro';
---
<div class="max-w-7xl relative h-full flex flex-row gap-10 items-center mx-auto">
    <div class="flex-1 flex flex-col gap-6">
        <ProfileBadge />
        <div class="flex flex-col gap-6">
            <p class="text-3xl @xl:text-4xl">
                Hola, soy <strong class="gradient-text text-accent"
                    >Ruben Cabrerizo Espinosa</strong
                >
            </p>
            <TypewriterText />
            <p class="leading-relaxed max-w-4xl">
                ¡Hola! Soy Ruben Cabrerizo, desarrollador web recién
                titulado en DAW (Desarrollo de Aplicaciones Web). Me
                apasiona crear soluciones digitales útiles, rápidas y
                bien diseñadas.
            </p>
            <HeroActions />
        </div>
    </div>
    <div class="hidden md:block">
        <SocialNetworks />
    </div>
</div>
